{
  "name": "shift-close-agent",
  "version": "1.0.0",
  "description": "Shift Close local attendance agent — syncs ZKTeco device with cloud",
  "author": "Westline",
  "main": "electron/main.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js",
    "electron": "electron .",
    "build": "node scripts/build-win.js",
    "build:package": "electron-packager . \"Shift Close Agent\" --platform=win32 --arch=x64 --out=dist --overwrite --ignore=node_modules/@electron/packager --prune=true",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-fetch": "^2.7.0",
    "zk-attendance-sdk": "^2.1.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.westline.shiftclose.agent",
    "productName": "Shift Close Agent",
    "asar": true,
    "asarUnpack": [
      "src/**"
    ],
    "win": {
      "target": "nsis",
      "sign": null,
      "signAndEditExecutable": false,
      "signDlls": false,
      "verifyUpdateCodeSignature": false,
      "forceCodeSigning": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "src/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ]
  }
}
