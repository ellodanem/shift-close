# Environment files (local dev)
# -----------------------------------------------------------------------------
# Next.js loads, in order (later overrides earlier):
#   .env  →  .env.local  →  (Vercel sets its own in production)
#
# Recommended:
#   .env        — shared defaults / production Neon URL (do not commit if it has secrets)
#   .env.local  — YOUR machine only (gitignored). Copy this file there and fill in.
#
# For Shift Close on Vercel, use the Neon integration database `shift-close-db`.
# Vercel → shiftcloser → Settings → Environment Variables → DATABASE_URL (Development).
# Or Neon console → shift-close-db → Connection string (pooled).
# -----------------------------------------------------------------------------

DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Required for login sessions. Min 16 characters. Generate: openssl rand -base64 32
# Use the SAME value in .env.local and Vercel → AUTH_SECRET (must match or sessions break).
AUTH_SECRET=""

# Optional: local Postgres for heavy dev (saves Neon compute). Example:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shiftclose?schema=public"
# Run: npx prisma migrate deploy && npx prisma db seed

# Optional: direct URL to the Shift Close Windows Agent NSIS installer (.exe). When set, Attendance →
# Windows Agent → “Download installer” redirects here (Vercel cannot ship the built .exe from repo).
# WINDOWS_AGENT_INSTALLER_URL="https://github.com/yourorg/yourrepo/releases/download/v1.0.0/Shift-Close-Agent-Setup.exe"

# Canonical public HTTPS URL (no trailing slash). Used for ADMS instructions, emails, reminders.
# Set after renaming a Vercel project so links match the hostname the ZKTeco device uses.
# APP_URL="https://yourproject.vercel.app"
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Gmail SMTP for sending reports (use Gmail App Password, not your normal password).
# SMTP_USER="your@gmail.com"
# SMTP_PASS="xxxx xxxx xxxx xxxx"
# EMAIL_FROM="your@gmail.com"

# Twilio WhatsApp for reminder notifications (optional).
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_WHATSAPP_FROM="whatsapp:+15558085661"
# TWILIO_WHATSAPP_ROSTER_TEMPLATE_SID="HX..."  # Content SID for roster template (required outside 24h window). Template vars: 1=week text, 2=image URL.

# Deftform API for syncing applications (optional).
# Create token at https://deftform.com → Settings → API. Form ID is in form detail page (lower right).
# DEFTFORM_ACCESS_TOKEN="your_token"
# DEFTFORM_FORM_ID="OUm6T9"
